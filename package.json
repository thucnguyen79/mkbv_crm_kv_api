{
  "name": "mkbv-crm-kv-api",
  "version": "0.1.0",
  "private": true,
  "description": "CRM & Messaging system integrated with KiotViet API",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "prisma": "pnpm --filter @mkbv/api prisma",
    "db:migrate": "pnpm --filter @mkbv/api prisma migrate dev",
    "db:seed": "pnpm --filter @mkbv/api db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma"
    ]
  }
}
