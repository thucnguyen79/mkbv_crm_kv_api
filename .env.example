# ===== Runtime =====
NODE_ENV=development
API_PORT=3000
WEB_PORT=3001
LOG_LEVEL=debug

# ===== PostgreSQL =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_local_dev
DATABASE_URL=postgresql://crm:crm_local_dev@postgres:5432/crm?schema=public

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== JWT =====
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ===== KiotViet =====
KIOTVIET_RETAILER=your-retailer-name
KIOTVIET_CLIENT_ID=
KIOTVIET_CLIENT_SECRET=
KIOTVIET_BASE_URL=https://public.kiotapi.com
KIOTVIET_TOKEN_URL=https://id.kiotviet.vn/connect/token
KIOTVIET_SCOPE=PublicApi.Access
KIOTVIET_WEBHOOK_SECRET=

# ===== Sync =====
SYNC_ENABLED=true
SYNC_CRON=*/5 * * * *

# ===== Messaging (providers configured later) =====
MESSAGING_DEFAULT_PROVIDER=stub
ZNS_PROVIDER=stub
SMS_PROVIDER=stub

# ===== Loyalty =====
# Xét hạng theo điểm tích luỹ (lifetime points), không phải VND.
# 1 điểm / LOYALTY_POINT_PER_VND đồng.
LOYALTY_POINT_PER_VND=10000
LOYALTY_TIER_MEMBER=300      # Hội viên
LOYALTY_TIER_SILVER=1000     # Bạc
LOYALTY_TIER_TITAN=2500      # Titan
LOYALTY_TIER_GOLD=5000       # Vàng
LOYALTY_TIER_PLATINUM=10000  # Bạch kim

# ===== Inventory =====
UPLOAD_DIR=./uploads
INVENTORY_LEAD_TIME_DAYS=7
INVENTORY_SAFETY_DAYS=3
INVENTORY_FAST_MOVER_DAILY=1      # > 1 unit/day = FAST_MOVER
INVENTORY_SLOW_MOVER_DAILY=0.1    # < 0.1 unit/day = SLOW_MOVER
INVENTORY_DEAD_AGING_DAYS=60      # Tồn > N ngày không bán = DEAD
INVENTORY_VELOCITY_WINDOW_DAYS=30
INVENTORY_VELOCITY_CRON=0 2 * * *  # 2am daily — recompute velocity + tag
INVENTORY_LOW_STOCK_CRON=0 8 * * * # 8am daily — check & notify

# ===== Web =====
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-nextauth-secret
